# App
VITE_APP_URL=https://your-app-url.com

# OD renewal via Bayarcash (optional). When true, use `npm run dev:server` or Vercel `/api/*` — not plain `vite`.
# VITE_OD_BAYARCASH_RENEWAL=true
# VITE_OD_PAYMENTS_ENABLED=true   # legacy alias
# VITE_PAYMENT_API_URL=http://localhost:3001   # if the SPA is not same-origin as `/api`

# Supabase (required)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-only (Bayarcash + checkout completion). Never expose in the browser.
# SUPABASE_SERVICE_ROLE_KEY=
# SUPABASE_URL=   # optional if same as VITE_SUPABASE_URL
# SUPABASE_ANON_KEY=   # optional if same as VITE_SUPABASE_ANON_KEY
# APP_BASE_URL=https://your-domain.com   # return URL host (preferred)
# APP_ORIGIN=https://your-domain.com     # alias of APP_BASE_URL
# BAYARCASH_PAT=                         # Bearer PAT (or BAYARCASH_API_TOKEN / BAYARCASH_TOKEN)
# BAYARCASH_SECRET=                      # HMAC secret (or BAYARCASH_API_SECRET)
# BAYARCASH_API_BASE=                    # optional full API root, e.g. https://api.console.bayarcash-sandbox.com/v3/
# BAYARCASH_SANDBOX=true
# BAYARCASH_API_VERSION=v2               # v2 | v3; inferred from BAYARCASH_API_BASE when possible
# BAYARCASH_PAID_STATUSES=3
# BAYARCASH_PAYMENT_CHANNEL=1            # or BAYARCASH_PAYMENT_CHANNELS=1,5,6,...
# BAYARCASH_PORTAL_KEY=

# Optional: Demo workspace (use only in dev; known credentials)
# VITE_ENABLE_DEMO_WORKSPACE=true

# Optional: Support email shown in app
# VITE_SUPPORT_EMAIL=support@example.com
